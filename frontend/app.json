{
  "expo": {
    "name": "ASK - المطبخ الحلبي السوري",
    "slug": "ask-aleppo-syrian-kitchen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "ask-kitchen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ask.aleppokitchen",
      "infoPlist": {
        "CFBundleDisplayName": "ASK Kitchen"
      }
    },
    "android": {
      "package": "com.ask.aleppokitchen",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#FFD700"
      },
      "edgeToEdgeEnabled": true,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A2E"
        }
      ],
      "expo-mail-composer",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "EXPO_PUBLIC_BACKEND_URL": "https://aleppo-culinary-app.preview.emergentagent.com",
      "eas": {
        "projectId": "f3bcf9dc-2877-4a14-89a6-b5e5b4a4b6be"
      },
      "router": {}
    },
    "owner": "sabah1960"
  }
}
